# =============================================================================
# Data Lakehouse Platform — Environment Variables
# Copy this file to .env and fill in your values before running docker-compose
# =============================================================================

# -----------------------------------------------------------------------------
# MinIO — Object Storage
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=http://minio:9000

# Bucket paths (s3a://<bucket>/<prefix>)
BRONZE_WAREHOUSE=s3a://warehouse/bronze
SILVER_WAREHOUSE=s3a://warehouse/silver
GOLD_WAREHOUSE=s3a://lakehouse/gold

# -----------------------------------------------------------------------------
# Nessie — Data Catalog
# -----------------------------------------------------------------------------
NESSIE_URI=http://nessie:19120/api/v1
NESSIE_BRANCH_BRONZE=bronze
NESSIE_BRANCH_SILVER=silver
NESSIE_BRANCH_GOLD=gold

# -----------------------------------------------------------------------------
# PostgreSQL — Source & Airflow Metadata
# -----------------------------------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=airflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Airflow metadata DB connection (auto-constructed from above in most setups)
# AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://<user>:<pass>@postgres/airflow

# -----------------------------------------------------------------------------
# Airflow
# -----------------------------------------------------------------------------
AIRFLOW_WWW_USER_USERNAME=
AIRFLOW_WWW_USER_PASSWORD=
# Generate a fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW__CORE__FERNET_KEY=

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=9094

# -----------------------------------------------------------------------------
# Debezium / Kafka Connect
# -----------------------------------------------------------------------------
DEBEZIUM_BOOTSTRAP_SERVERS=kafka:9092

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# -----------------------------------------------------------------------------
# Trino
# -----------------------------------------------------------------------------
TRINO_PORT=8080

# -----------------------------------------------------------------------------
# dbt
# -----------------------------------------------------------------------------
DBT_PROFILES_DIR=/usr/app/dbt
